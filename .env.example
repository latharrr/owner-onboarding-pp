# ============================================================
# Picapool PG Owner Onboarding — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Google Apps Script ───────────────────────────────────────
# The Web App URL from your deployed Apps Script
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# A long random secret shared between Next.js and Apps Script
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPS_SCRIPT_SECRET=your_shared_secret_here

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI PG Discovery (Groq) ────────────────────────────────────
# Server-side only — never exposed to the client. Get a free key at
# https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional — defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
